# Google Search Console MCP — private server
GSC_CREDENTIALS_PATH=/absolute/path/to/service-account.json
GSC_SKIP_OAUTH=true
GSC_ALLOW_DESTRUCTIVE=false
GSC_DATA_STATE=all

# Default properties for SEO tools
PRIMARY_GSC_PROPERTY=https://example.com/
SECONDARY_GSC_PROPERTY=
TARGET_PATH_PREFIX=

# Analytics defaults
DEFAULT_DAYS=90
MIN_IMPRESSIONS=50
MAX_ROWS=500

# Transport: streamable-http (remote) or stdio (local)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=3001
