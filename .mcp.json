{
  "mcpServers": {
    "gsc-remote": {
      "url": "https://your-domain.example/mcp",
      "transport": "streamable-http"
    },
    "gsc-local": {
      "command": "uv",
      "args": ["run", "mcp-gsc"],
      "env": {
        "GSC_CREDENTIALS_PATH": "/absolute/path/to/service-account.json",
        "GSC_SKIP_OAUTH": "true",
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
